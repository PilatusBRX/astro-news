---
import { getCollection } from "astro:content";
import { type BlogProps } from "@/types/blog";
import { slugify } from "@/utils/slugify";

// Redireciona para a primeira página de cada tag
export async function getStaticPaths() {
  const allPosts = (await getCollection("blog")) as BlogProps[];

  // Extrair todas as tags únicas
  const uniqueTags = [
    ...new Set(allPosts.map((post) => post.data.tags).flat()),
  ];

  // Criar um caminho para cada tag
  return uniqueTags.map((tag) => {
    return {
      params: { tag: slugify(tag) },
    };
  });
}

const { tag } = Astro.params;

// Redireciona para a página 1 da tag
return Astro.redirect(`/tags/${tag}/1`);
---
